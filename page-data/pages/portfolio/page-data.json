dth: 960px) 100vw, 960px\"\n              type=\"image/webp\"\n            />\n          <source\n            srcset=\"/static/123bf7f7c44760a2eb66c656a9a99930/09b79/port-02.jpg 240w,\n/static/123bf7f7c44760a2eb66c656a9a99930/7cc5e/port-02.jpg 480w,\n/static/123bf7f7c44760a2eb66c656a9a99930/6a068/port-02.jpg 960w,\n/static/123bf7f7c44760a2eb66c656a9a99930/644c5/port-02.jpg 1440w,\n/static/123bf7f7c44760a2eb66c656a9a99930/c06f5/port-02.jpg 1668w\"\n            sizes=\"(max-width: 960px) 100vw, 960px\"\n            type=\"image/jpeg\"\n          />\n          <img\n            class=\"gatsby-resp-image-image\"\n            src=\"/static/123bf7f7c44760a2eb66c656a9a99930/6a068/port-02.jpg\"\n            alt=\"마이페이지\"\n            title=\"마이페이지\"\n            loading=\"lazy\"\n            style=\"width:100%;height:100%;margin:0;vertical-align:middle;position:absolute;top:0;left:0;\"\n          />\n        </picture>\n  </a>\n    </span>\n<em>마이페이지</em></p>\n<h4 id=\"기술내용\" style=\"position:relative;\"><a href=\"#%EA%B8%B0%EC%88%A0%EB%82%B4%EC%9A%A9\" aria-label=\"기술내용 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" focusable=\"false\" height=\"16\" version=\"1.1\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>기술내용</h4>\n<ol>\n<li>리액트</li>\n<li>nodeJS를 이용한 express 서버</li>\n<li>MongoDB 데이터베이스</li>\n<li>부트스트랩 </li>\n</ol>\n<p>첫 프로젝트고 콘솔 프로그래밍만 하다가 웹프로그래밍을 하려다 보니깐 정말 신세계를 느꼈다.\n물론 다양한 문제들도 많이 접했다.\n가장 어려웠던 점은 jwt 발행과 비밀번호 암호화였다. 비밀번호를 데이터베이스에 그냥 저장하면 정보통신망 이용촉진 및 정보보호 등에 관한 법률 제28조제1항제4호에 의해 처벌받는다고 한다. 그래서 결국 크립토와 salt를 이용해 비밀번호를 암호화했다 <del>(너무 어려웠다.)</del> .\n또한 로그인했을때 jwt을 발행함으로서 접근권한을 부여했다. 세션을 이용한 로그인을 할지 고민했지만 jwt가 뭔가 이름이 멋져서 jwt로 선택했다. 회원가입, 글 발행, 이미지 저장, 쿠키 저장 및 삭제, 디비 연동, 라우팅 등 직접 구현했고,\n정말 많을것을 배웠다. 6월달에 실제 서비스를 런칭할 계획인데 아직 불안하다.   </p>","frontmatter":{"title":"포트폴리오","date":null,"description":null,"socialImage":{"publicURL":"/static/b8d80fa05dac23fa24640a09afd1b43f/port-01.jpg"}}}},"pageContext":{"slug":"/pages/portfolio/"}},"staticQueryHashes":["251939775","401334301","825871152"]}